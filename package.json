{
  "name": "synthetic-investigators",
  "version": "0.2.0",
  "description": "AI models as CoC investigators — multi-model TRPG experiment",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "server:dev": "tsx watch server/api.ts",
    "client:dev": "vite --config client/vite.config.ts",
    "build": "vite build --config client/vite.config.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@google/generative-ai": "^0.21.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.1",
    "express": "^4.21.0",
    "ollama": "^0.5.0",
    "openai": "^4.77.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "ws": "^8.18.0",
    "zod": "^3.24.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "playwright": "^1.59.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^5.4.0"
  }
}
